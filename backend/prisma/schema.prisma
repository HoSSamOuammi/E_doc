generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  nom          String
  prenom       String
  email        String        @unique
  password     String
  role         String
  inscriptions Inscription[]

  @@map("users")
}

model Formation {
  id           Int           @id @default(autoincrement())
  titre        String
  duree        String
  niveau       String        @default("Debutant")
  inscriptions Inscription[]

  @@map("formations")
}

model Inscription {
  id          Int       @id @default(autoincrement())
  etudiantId  Int       @map("etudiant_id")
  formationId Int       @map("formation_id")
  etudiant    User      @relation(fields: [etudiantId], references: [id], onDelete: Cascade)
  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([etudiantId, formationId])
  @@map("inscriptions")
}
